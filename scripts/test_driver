#!/usr/bin/env bash 

# Variables
pkg_dir="${HOME}/catkin_ws/src/pgmappingcooperativo"
rviz_dir="${pkg_dir}/rviz"
config_dir="${pkg_dir}/config"
log_dir="${pkg_dir}/log"
SCRIPT_DIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"


function count_executed_tests(){
  local test_param=$1
  local test_value=$2

  local count=0
  for log in $log_dir/* ; do
    if [ -f "$log/termination.yaml" ] ; then
      local val=$(ruby -r yaml -e "puts YAML.load_file(ARGV[0])[\"$test_param\"]" "$log/rosparams.yaml")
      if [ $val = $test_value ] ; then
        ((count=count+1))
      fi
    fi
  done
  echo $count
}

function remaining_tests(){
  local test_param=$1
  local test_value=$2
  local desired_tests=$3

  local current=$(count_executed_tests $test_param $test_value)

  local remaining=0
  ((remaining=desired_tests-current))

  echo $remaining
}

function execute_remaining_tests(){
  local test_param=$1
  local test_value=$2
  local desired_tests=$3
  local test_cmd=$4

  local remaining=$(remaining_tests $test_param $test_value $desired_tests)
  while [ $remaining  -gt 0 ] ; do
    for (( n = 0 ; n < $remaining ; n++ )); do
      $test_cmd
    done
    remaining=$(remaining_tests $test_param $test_value $desired_tests)
  done
}

test_num=20

execute_remaining_tests "cell_size" 1.0      $test_num "$SCRIPT_DIR/pgmch test-nocompile office 5 1.0      1000s"

execute_remaining_tests "cell_size" 0.5      $test_num "$SCRIPT_DIR/pgmch test-nocompile office 5 0.5      1900s"

execute_remaining_tests "cell_size" 0.333333 $test_num "$SCRIPT_DIR/pgmch test-nocompile office 5 0.333333 2900s"

execute_remaining_tests "cell_size" 0.25     $test_num "$SCRIPT_DIR/pgmch test-nocompile office 5 0.25     4000s"
