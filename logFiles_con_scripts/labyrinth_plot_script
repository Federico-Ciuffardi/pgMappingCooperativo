set term pngcairo size 1024,768
set output "labyrinth_graph.png"
set xlabel "Cantidad de Robots"
set ylabel "Tiempo de Ejecucion (s)"
set yrange [0:]
set xrange [0.5:5.5]
#set style line 10 linetype 2 lc rgb 'blue'
set print "labyrinth_graph.dat"

stats 'labyrinth_tiemposEjecucionG1.dat' nooutput
print 1, STATS_mean , STATS_stddev
stats 'labyrinth_tiemposEjecucionG2.dat' nooutput
print 2, STATS_mean , STATS_stddev
stats 'labyrinth_tiemposEjecucionG3.dat' nooutput
print 3, STATS_mean , STATS_stddev
stats 'labyrinth_tiemposEjecucionG4.dat' nooutput
print 4, STATS_mean , STATS_stddev
stats 'labyrinth_tiemposEjecucionG5.dat' nooutput
print 5, STATS_mean , STATS_stddev

plot "labyrinth_graph.dat" u 1:2 notitle w lines lw 0.5 lc rgb 'grey', "labyrinth_graph.dat" u 1:2:3 notitle with yerrorbars lc rgb 'blue' pt 1