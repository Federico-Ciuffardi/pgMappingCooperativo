set term pngcairo size 1024,768
set output "office_graph.png"
set xlabel "Cantidad de Robots"
set ylabel "Tiempo de Ejecucion (s)"
set yrange [0:]
set xrange [0.5:5.5]
#set style line 10 linetype 2 lc rgb 'blue'
set print "office_graph.dat"

stats 'office_tiemposEjecucionG1.dat' nooutput
print 1, STATS_mean , STATS_stddev
stats 'office_tiemposEjecucionG2.dat' nooutput
print 2, STATS_mean , STATS_stddev
stats 'office_tiemposEjecucionG3.dat' nooutput
print 3, STATS_mean , STATS_stddev
stats 'office_tiemposEjecucionG4.dat' nooutput
print 4, STATS_mean , STATS_stddev
stats 'office_tiemposEjecucionG5.dat' nooutput
print 5, STATS_mean , STATS_stddev

plot "office_graph.dat" u 1:2 notitle w lines lw 0.5 lc rgb 'grey', "office_graph.dat" u 1:2:3 notitle with yerrorbars lc rgb 'blue' pt 1