<launch>
  <arg name="ns_name" default="atrv0"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="init_pose_x" default="0.0" />
  <arg name="init_pose_y" default="0.0" />
  <arg name="init_pose_z" default="0.0" />
  <arg name="init_pose_yaw" default="0.0" />

      <group ns="$(arg ns_name)">

        <param name="robot_description" command="$(find xacro)/xacro '$(find tscf_exploration)/urdf/pioneer3dx.xacro'" />

        <node name="joint_state_publisher_$(arg ns_name)" pkg="joint_state_publisher" type="joint_state_publisher" ></node>

        <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher_$(arg ns_name)" output="screen" >
          <param name="tf_prefix" type="string" value="$(arg ns_name)_tf" />
        </node>

        <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
          <remap from="scan" to="/$(arg ns_name)/scan"/>
          <param name="base_frame" value="$(arg ns_name)_tf/base_footprint"/>
          <param name="odom_frame" value="$(arg ns_name)_tf/odom"/>
          <param name="map_frame" value="/world"/>
          <param name="minimumScore" value="100"/>
          <param name="map_update_interval" value="1.0"/>
          <param name="temporalUpdate" value="1.0"/>
          <param name="linearUpdate" value="1.0"/>
          <param name="maxUrange" value="5.95"/>
          <param name="maxRange" value="6.0"/>
          <param name="particles" value="200"/>
          <param name="srr" value="0.0"/>
          <param name="srt" value="0.0"/>
          <param name="str" value="0.0"/>
          <param name="stt" value="0.0"/>
          <param name="xmin" value="-60.0"/>
          <param name="ymin" value="-60.0"/>
          <param name="xmax" value="70.0"/>
          <param name="ymax" value="70.0"/>
          <param name="delta" value="1"/>

        </node>

        <node pkg="tscf_exploration" type="tscf_exploration_move_controller" name="$(arg ns_name)_move_controller" required="true" />

        <node pkg="tscf_exploration" type="tscf_exploration_robot" name="$(arg ns_name)_robot" required="true">
          <param name="init_pose_x" value="$(arg init_pose_x)"/>
          <param name="init_pose_y" value="$(arg init_pose_y)"/>
        </node>
        <!--
      -->

    </group>

</launch>
