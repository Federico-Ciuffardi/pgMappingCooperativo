<?xml version="1.0"?>
<launch>
  <arg name="ns" default="p3dx"/>
  <arg name="x" default="0" />
  <arg name="y" default="0" />
  <arg name="z" default="0" />

  <arg name="cell_size" default="1" />

  <param name ="/use_sim_time" value="true"/>

  <include file="$(find p3dx_gazebo)/launch/p3dx.launch" >
        <arg name="x"  value="$(arg x)" />
        <arg name="y"  value="$(arg y)" />
        <arg name="z"  value="$(arg z)" />
        <arg name="ns" value="$(arg ns)" />
  </include>

  <group ns="$(arg ns)">
    <!-- waypoint_navigation -->
    <node pkg="waypoint_navigation" type="waypoint_navigation_node" name="move_controller" required="true" />

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" required="true">
      <rosparam file="$(find pgmappingcooperativo)/config/move_base/costmap_common_params.yaml" command="load" ns="local_costmap" />
      <rosparam file="$(find pgmappingcooperativo)/config/move_base/costmap_common_params.yaml" command="load" ns="global_costmap" />

      <rosparam file="$(find pgmappingcooperativo)/config/move_base/local_costmap_params.yaml" command="load" />
      <rosparam file="$(find pgmappingcooperativo)/config/move_base/global_costmap_params.yaml" command="load" /> 

      <rosparam file="$(find pgmappingcooperativo)/config/move_base/base_local_planner_params.yaml" command="load" />

      <param name="global_costmap/resolution" value="$(arg cell_size)"/>

       <!-- Set robot specific information -->

      <param name="global_costmap/global_frame" value="map"/>
      <param name="global_costmap/robot_base_frame" value="$(arg ns)/base_link"/>

      <param name="global_costmap/laser_scan/sensor_frame" value="$(arg ns)/lms100"/>
      <param name="global_costmap/laser_scan/topic" value="/$(arg ns)/laser/scan"/>

      <param name="local_costmap/global_frame" value="$(arg ns)/odom"/>
      <param name="local_costmap/robot_base_frame" value="$(arg ns)/base_link"/>

      <param name="local_costmap/laser_scan/sensor_frame" value="$(arg ns)/lms100"/>
      <param name="local_costmap/laser_scan/topic" value="/$(arg ns)/laser/scan"/>
    </node>

    <!-- move_controller -->
    <node pkg="pgmappingcooperativo" type="pgmappingcooperativo_move_controller" name="$(arg ns)_move_controller" required="true" />

    <!-- robot controller -->
    <node pkg="pgmappingcooperativo" type="pgmappingcooperativo_robot" name="$(arg ns)_robot" required="true">
      <param name="init_pose_x" value="$(arg x)"/>
      <param name="init_pose_y" value="$(arg y)"/>
    </node>

  </group>
</launch>
